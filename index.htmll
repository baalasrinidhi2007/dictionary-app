<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Dictionary App</title> 

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{

min-height:100vh;

display:flex;
justify-content:center;
align-items:center;

background:linear-gradient(
135deg,
#ff9a9e,
#fad0c4,
#fad0c4,
#a18cd1,
#fbc2eb
);

background-size:400% 400%;
animation:bg 12s ease infinite;
padding:20px;
}

@keyframes bg{

0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}

}

.container{

width:100%;
max-width:700px;

padding:30px;

background:rgba(255,255,255,0.25);

backdrop-filter:blur(15px);

border-radius:25px;

box-shadow:0 8px 32px rgba(0,0,0,.2);

color:white;
}

.top{

display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

h1{

font-size:2rem;
}

button{

border:none;
cursor:pointer;
}

.mode{

padding:10px 15px;
border-radius:10px;
font-size:1rem;
}

.search{

display:flex;
gap:10px;
margin-bottom:20px;
}

input{

flex:1;
padding:15px;

border:none;
outline:none;

border-radius:12px;

font-size:16px;
}

.searchBtn{

padding:15px 20px;

background:#6c63ff;

color:white;

border-radius:12px;
font-weight:bold;
}

.searchBtn:hover{

transform:scale(1.05);
}

.result{

margin-top:20px;
}

.word{

font-size:2rem;
font-weight:bold;
}

.type{

opacity:.8;
margin-bottom:10px;
}

.card{

background:rgba(255,255,255,.15);

padding:15px;

margin-top:15px;

border-radius:15px;
}

.synonyms{

display:flex;
flex-wrap:wrap;
gap:10px;
margin-top:10px;
}

.synonyms span{

background:rgba(255,255,255,.2);

padding:8px 12px;

border-radius:20px;
}

.audioBtn{

margin-top:10px;

padding:10px 15px;

border-radius:10px;

background:#00c9a7;

color:white;
}

.dark{

background:#121212;
color:white;
}

.dark .container{

background:rgba(0,0,0,.35);
}

</style>
</head>

<body>

<div class="container">

<div class="top">

<h1>📖 Dictionary</h1>

<button
class="mode"
onclick="toggleMode()">
🌙
</button>

</div>

<div class="search">

<input
id="wordInput"
placeholder="Search a word...">

<button
class="searchBtn"
onclick="searchWord()">

🔍 Search

</button>

</div>

<div
class="result"
id="result">

<h2>✨ Search a word to begin</h2>

</div>

</div>

<script>

async function searchWord(){

const word=
document.getElementById("wordInput").value;

if(!word)return;

const result=
document.getElementById("result");

result.innerHTML=
"⏳ Searching...";

try{

const response=
await fetch(
`https://api.dictionaryapi.dev/api/v2/entries/en/${word}`
);

const data=
await response.json();

const item=data[0];

let meaning=
item.meanings[0];

let definition=
meaning.definitions[0];

let audio="";

if(item.phonetics.length>0){

audio=item.phonetics.find(
p=>p.audio
)?.audio || "";

}

let synonyms=
meaning.synonyms.slice(0,8);

result.innerHTML=`

<div class="word">
${item.word}
</div>

<div class="type">
${meaning.partOfSpeech}
</div>

<div class="card">

<h3>📖 Definition</h3>

<p>
${definition.definition}
</p>

</div>

<div class="card">

<h3>📝 Example</h3>

<p>
${definition.example || "No example available"}
</p>

</div>

<div class="card">

<h3>🔄 Synonyms</h3>

<div class="synonyms">

${
synonyms.length
?
synonyms.map(
s=>`<span>${s}</span>`
).join("")
:
"No synonyms found"
}

</div>

</div>

${
audio
?
`
<button
class="audioBtn"
onclick="playAudio('${audio}')">

🔊 Pronunciation

</button>
`
:
""
}

`;

}

catch{

result.innerHTML=
"❌ Word not found";
}

}

function playAudio(url){

new Audio(url).play();

}

function toggleMode(){

document.body.classList.toggle(
"dark"
);

}

document
.getElementById("wordInput")
.addEventListener(
"keypress",
function(e){

if(e.key==="Enter"){

searchWord();

}

}
);

</script>

</body>
</html>
